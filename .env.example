# ── Model ─────────────────────────────────────────────────────────────────────
# HuggingFace model ID or local path
TRIO_MODEL=mlx-community/Qwen3.5-2B-MLX-4bit

# Path to LoRA adapter directory (contains adapters.safetensors + adapter_config.json)
TRIO_ADAPTER_PATH=

# ── Server ────────────────────────────────────────────────────────────────────
TRIO_HOST=0.0.0.0
TRIO_PORT=8100

# Bearer token for API authentication (if unset, server is unauthenticated)
TRIO_API_KEY=

# Structured JSON logging (1 or true to enable)
TRIO_LOG_JSON=

# ── Video Pipeline ────────────────────────────────────────────────────────────
TRIO_VIDEO_FPS=2.0
TRIO_VIDEO_MAX_FRAMES=128
TRIO_VIDEO_MIN_FRAMES=4

# ── Temporal Dedup ────────────────────────────────────────────────────────────
TRIO_DEDUP_ENABLED=true
TRIO_DEDUP_THRESHOLD=0.95

# ── Motion Gate ───────────────────────────────────────────────────────────────
TRIO_MOTION_ENABLED=false
TRIO_MOTION_THRESHOLD=0.03

# ── Generation ────────────────────────────────────────────────────────────────
TRIO_MAX_TOKENS=512
TRIO_TEMPERATURE=0.0
TRIO_TOP_P=1.0

# ── ToMe (Token Merging) ─────────────────────────────────────────────────────
TRIO_TOME_ENABLED=false
TRIO_TOME_R=4
TRIO_TOME_METRIC=hidden
TRIO_TOME_MIN_KEEP_RATIO=0.3
TRIO_TOME_ADAPTIVE=false
TRIO_TOME_CONTENT_AWARE=false

# ── Visual Similarity KV Reuse ───────────────────────────────────────────────
# 0 = disabled, 0.95 = typical value for consecutive-frame KV reuse
TRIO_VISUAL_SIMILARITY_THRESHOLD=0.0

# ── Early Stopping ───────────────────────────────────────────────────────────
TRIO_EARLY_STOP=false
TRIO_EARLY_STOP_THRESHOLD=0.8

# ── StreamMem (streaming KV cache for continuous video) ──────────────────────
TRIO_STREAMING_MEMORY_ENABLED=false
TRIO_STREAMING_MEMORY_BUDGET=6000
TRIO_STREAMING_MEMORY_PROTOTYPE_RATIO=0.1
TRIO_STREAMING_MEMORY_SINK_TOKENS=4

# ── Visual Token Compression (post-encoder) ──────────────────────────────────
TRIO_COMPRESS_ENABLED=false
TRIO_COMPRESS_RATIO=0.5

# ── Auto-Optimize ─────────────────────────────────────────────────────────────
# Apply benchmark-proven settings from model profile. Set false for manual-only.
TRIO_AUTO_OPTIMIZE=true

# ── Remote VLM (OpenAI-compatible Chat API) ──────────────────────────────────
# When set, all VLM inference is routed to this API instead of local GPU.
# The local /describe, /crop-describe, /detect endpoints remain unchanged.
#
# DashScope (Qwen VL):  https://dashscope.aliyuncs.com/compatible-mode/v1
# OpenAI:               https://api.openai.com/v1
TRIO_REMOTE_VLM_URL=
TRIO_REMOTE_VLM_API_KEY=
TRIO_REMOTE_VLM_MODEL=qwen-vl-plus

# ── YOLO ─────────────────────────────────────────────────────────────────────
# Path to YOLO ONNX model (auto-downloaded if unset)
TRIO_YOLO_MODEL=

# ── Cache (Phase 2) ──────────────────────────────────────────────────────────
TRIO_CACHE_ENABLED=false
TRIO_CACHE_MAX_ENTRIES=50
TRIO_CACHE_MAX_MEMORY_MB=2048
